.data
    mesaj1: .asciiz "Kaca kadar olan sayilar toplansin: "
    mesaj2: .asciiz "Sonuc: "

.text
main:
    
    li $v0, 4
    la $a0, mesaj1
    syscall

    li $v0, 5
    syscall
    move $t1, $v0       

    
    li $t0, 1           
    li $s0, 0            

loop:
    
    add $s0, $s0, $t0    
    addi $t0, $t0, 1     
    ble $t0, $t1, loop   

yazdir:
    
    li $v0, 4
    la $a0, mesaj2
    syscall

    
    li $v0, 1
    move $a0, $s0
    syscall

bitir:
    li $v0, 10
    syscall
